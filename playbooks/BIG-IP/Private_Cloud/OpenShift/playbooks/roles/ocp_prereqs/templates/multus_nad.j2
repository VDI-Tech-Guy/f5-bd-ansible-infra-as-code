{# templates/multus_nad.j2 #}
{# Rendered once per item in f5_networks (excluding mgmt) #}
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: "{{ nad_item.nad_name }}"
  namespace: "{{ ocp_namespace }}"
spec:
  config: |
    {
      "cniVersion": "0.3.1",
      "name": "{{ nad_item.nad_name }}",
      "type": "bridge",
      "bridge": "{{ nad_item.bridge }}",
      "vlan": {{ nad_item.vlan_id }},
      "ipam": {}
    }
