{# templates/vm_manifest.j2 #}
{# Rendered per-node #}
apiVersion: kubevirt.io/v1
kind: VirtualMachine
metadata:
  name: "{{ node_name }}"
  namespace: "{{ ocp_namespace }}"
  labels:
    app: f5-bigip
    role: "{{ 'primary' if node_name == f5_primary_node else 'secondary' }}"
spec:
  running: true
  template:
    metadata:
      labels:
        kubevirt.io/vm: "{{ node_name }}"
    spec:
      nodeSelector:
        node-role.kubernetes.io/worker: ""   # pin to worker nodes
      affinity:
        podAntiAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            - labelSelector:
                matchLabels:
                  app: f5-bigip
              topologyKey: kubernetes.io/hostname   # force HA nodes to different hosts

      domain:
        cpu:
          cores: {{ f5_vm_cpu }}
        memory:
          guest: "{{ f5_vm_memory }}"
        devices:
          disks:
            - name: rootdisk
              disk:
                bus: virtio
              bootOrder: 1
            - name: cloudinitdisk
              disk:
                bus: virtio
          interfaces:
            - name: mgmt
              bridge: {}
            - name: internal
              bridge: {}
            - name: external
              bridge: {}
            - name: ha
              bridge: {}

      networks:
        - name: mgmt
          multus:
            networkName: "{{ ocp_namespace }}/f5-mgmt"
        - name: internal
          multus:
            networkName: "{{ ocp_namespace }}/f5-internal"
        - name: external
          multus:
            networkName: "{{ ocp_namespace }}/f5-external"
        - name: ha
          multus:
            networkName: "{{ ocp_namespace }}/f5-ha"

      volumes:
        - name: rootdisk
          dataVolume:
            name: "{{ f5_datavolume_name }}-{{ node_name }}"
        - name: cloudinitdisk
          cloudInitNoCloud:
            secretRef:
              name: "cloudinit-{{ node_name }}"
