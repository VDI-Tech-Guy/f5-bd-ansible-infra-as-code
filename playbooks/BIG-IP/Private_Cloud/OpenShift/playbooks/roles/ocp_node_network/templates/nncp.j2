apiVersion: nmstate.io/v1
kind: NodeNetworkConfigurationPolicy
metadata:
  name: ovs-vms
spec:
  nodeSelector:
    node-role.kubernetes.io/worker: ''
  desiredState:
    interfaces:
    - name: ovs-vms
      type: ovs-bridge
      state: up
      bridge:
        allow-extra-patch-ports: true
        options:
          stp: true
        port:
          - name: ens1f1
    ovn:
      bridge-mappings:
      {% for vlan in f5_networks %}
      - localnet: "{{ vlan.nad_name }}"
        bridge: ovs-vms
        state: present
      {% endfor %}
